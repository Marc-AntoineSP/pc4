COMPOSE_PROJECT_NAME=app-staging

# Symfony
APP_ENV=prod
APP_DEBUG=0
APP_RUNTIME_ENV=staging
APP_SECRET=app-staging
POSTGRES_DB=app_staging
POSTGRES_USER=app_staging
POSTGRES_PASSWORD=app-staging
POSTGRES_VERSION=16
POSTGRES_CHARSET=utf8

# Lexik JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=app-staging

# MinIO
MINIO_ROOT_USER=minio_staging
MINIO_ROOT_PASSWORD=app-staging

# Hosts
APP_HOST=pc4.staging.arukanin.fr
S3_HOST=s3.pc4.staging.arukanin.fr
MINIO_CONSOLE_HOST=minio.pc4.staging.arukanin.fr
DEFAULT_URI=https://pc4.staging.arukanin.fr
