{% extends 'layout/SidebarLayout.html.twig' %}

{% block title %}My books{% endblock %}

{% block main_content %}
    <div class="drawer-content flex h-screen flex-col overflow-hidden book-catalog-page">
        <main class="scrollbar-hidden mx-auto flex h-full w-full max-w-7xl flex-col overflow-auto p-4 lg:p-8">
            <header class="mb-6 flex flex-wrap items-end justify-between gap-3 border-b border-primary-content/20 pb-4">
                <div>
                    <h1 class="text-4xl font-serif font-bold lg:text-5xl">My books</h1>
                    <p class="mt-2 text-sm italic text-primary-content/70 lg:text-base">Welcome to your books page, {{ app.user.email }}.</p>
                </div>
                <div class="badge badge-secondary badge-outline rounded-none px-4 py-3 font-sans text-[11px] font-bold uppercase tracking-[0.22em]">
                    {{ books|length }} books
                </div>
            </header>

            {% if books is empty %}
                <div role="alert" class="alert border-primary-content/30 bg-base-100/10 text-primary-content shadow-lg">
                    <span>You have no books on loan right now.</span>
                </div>
            {% else %}
                <div class="space-y-8">
                    {% for book in books %}
                        {% set bookType = book.type ? book.type.label() : 'Unclassified' %}
                        <article class="card rounded-none border border-primary-content/20 bg-primary/25 shadow-xl">
                            <div class="card-body p-4 lg:p-6">
                                <header class="mb-6 flex flex-wrap items-start justify-between gap-4 border-b border-primary-content/20 pb-4">
                                    <div>
                                        <h2 class="text-3xl leading-tight font-serif font-bold lg:text-4xl">{{ book.title }}</h2>
                                        <p class="mt-2 text-sm italic text-primary-content/70 lg:text-base">Book id : #{{ book.id }}.</p>
                                    </div>
                                    <div class="badge badge-secondary badge-outline rounded-none px-4 py-3 font-sans text-[11px] font-bold uppercase tracking-[0.22em]">
                                        {{ bookType }}
                                    </div>
                                </header>

                                <section class="book-detail-layout">
                                    <aside class="book-detail-pane">
                                        <div class="book-detail-card">
                                            <twig:Book
                                                id="{{ book.id }}"
                                                title="{{ book.title }}"
                                                type="{{ bookType }}"
                                                author="{{ book.author }}"
                                                pages="{{ book.pages }}"
                                                available="{{ book.isAvailable ? 'true' : 'false' }}"
                                                showAvailability="true"
                                                linkToDetail="false"
                                            />
                                        </div>
                                        <form method="post" action="{{ path('app_book_return', { id: book.id }) }}" class="mt-4">
                                            <input type="hidden" name="_token" value="{{ csrf_token('return_book_' ~ book.id) }}">
                                            <button type="submit" class="btn btn-lg btn-secondary w-full rounded-none font-sans text-base font-bold tracking-[0.18em] text-secondary-content">
                                                RETURN BOOK
                                            </button>
                                        </form>
                                    </aside>

                                    <section class="book-detail-text">
                                        <article class="book-parchment-panel">
                                            <div class="book-section-head">Description</div>
                                            <p class="book-section-copy">{{ book.description|default('No description provided.')|nl2br }}</p>
                                        </article>

                                        <article class="book-parchment-panel">
                                            <div class="book-section-head">Summary</div>
                                            <p class="book-section-copy">{{ book.summary|default('No summary provided.')|nl2br }}</p>
                                        </article>
                                    </section>
                                </section>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% endif %}
        </main>
    </div>
{% endblock %}
