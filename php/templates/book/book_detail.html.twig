{% extends 'layout/SidebarLayout.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block main_content %}
    {% set bookType = book.type ? book.type.label() : 'Unclassified' %}

    <div class="drawer-content flex h-screen flex-col overflow-hidden book-catalog-page">
        <main class="scrollbar-hidden mx-auto flex h-full w-full max-w-7xl flex-col overflow-auto p-4 lg:p-8">
            <header class="mb-6 flex flex-wrap items-start justify-between gap-4 border-b border-primary-content/20 pb-4">
                <div>
                    <a href="{{ path('app_book_all') }}" class="inline-flex items-center gap-2 border border-primary-content/35 px-3 py-1.5 font-sans text-[10px] font-bold uppercase tracking-[0.2em] text-primary-content/80 transition-colors hover:bg-primary-content/10 hover:text-primary-content">
                        <span aria-hidden="true">&#8592;</span>
                        Back to catalog
                    </a>
                    <h1 class="mt-4 text-4xl leading-tight font-serif font-bold lg:text-5xl">{{ book.title }}</h1>
                    <p class="mt-2 text-sm italic text-primary-content/70 lg:text-base">Book id : #{{ book.id }}.</p>
                </div>
                <div class="badge badge-secondary badge-outline rounded-none px-4 py-3 font-sans text-[11px] font-bold uppercase tracking-[0.22em]">
                    {{ bookType }}
                </div>
            </header>

            <section class="book-detail-layout">
                <aside class="book-detail-pane">
                    <div class="book-detail-card">
                        <twig:Book
                            id="{{ book.id }}"
                            title="{{ book.title }}"
                            type="{{ bookType }}"
                            author="{{ book.author }}"
                            pages="{{ book.pages }}"
                            available="{{ book.isAvailable ? 'true' : 'false' }}"
                            showAvailability="true"
                            linkToDetail="false"
                        />
                    </div>
                </aside>

                <section class="book-detail-text">
                    <article class="book-parchment-panel">
                        <div class="book-section-head">Description</div>
                        <p class="book-section-copy">{{ book.description|default('No description provided.')|nl2br }}</p>
                    </article>

                    <article class="book-parchment-panel">
                        <div class="book-section-head">Summary</div>
                        <p class="book-section-copy">{{ book.summary|default('No summary provided.')|nl2br }}</p>
                    </article>
                </section>
            </section>
        </main>
    </div>
{% endblock %}
