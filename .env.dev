COMPOSE_PROJECT_NAME=app-dev

# Symfony
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-dev-app-secret
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-dev-db-password
POSTGRES_VERSION=16
POSTGRES_CHARSET=utf8

# Lexik JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me-dev-jwt-passphrase

# Notifuse
NOTIFUSE_TOKEN=change-me-dev-notifuse-token
DB_HOST=database
DB_PORT=5432
DB_USER=app
DB_PASSWORD=change-me-dev-db-password
SECRET_KEY=change-me-dev-notifuse-secret

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-dev-minio-password

# Hosts
APP_HOST=app.local
NOTIFUSE_HOST=notifuse.local
S3_HOST=s3.local
MINIO_CONSOLE_HOST=minio.local
DEFAULT_URI=https://app.local

# Dev-only
XDEBUG_MODE=off
