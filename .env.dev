COMPOSE_PROJECT_NAME=app-dev

# Symfony
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change-me-dev-app-secret
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-dev-db-password
POSTGRES_VERSION=16
POSTGRES_CHARSET=utf8

# Lexik JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me-dev-jwt-passphrase

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-dev-minio-password

# Hosts
APP_HOST=dev.app.local
S3_HOST=dev.s3.local
MINIO_CONSOLE_HOST=dev.minio.local
DEFAULT_URI=https://dev.app.local

# Dev
XDEBUG_MODE=off
