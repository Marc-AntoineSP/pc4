{
	auto_https disable_redirects

	servers {
		trusted_proxies static private_ranges
	}
}

(dev_tls) {
	tls internal
}

(security_headers) {
	header {
		-Server
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

(proxy_target) {
	encode zstd gzip
	import security_headers

	reverse_proxy {
		dynamic a {
			name {args[0]}
			port {args[1]}
			refresh 30s
		}

		lb_policy least_conn
		fail_duration 15s
		health_interval 30s

		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}
	}
}

http://{$APP_HOST} {
	redir https://{$APP_HOST}{uri} permanent
}

https://{$APP_HOST} {
	import dev_tls
	import proxy_target app 80
}

http://{$S3_HOST} {
	redir https://{$S3_HOST}{uri} permanent
}

https://{$S3_HOST} {
	import dev_tls
	import proxy_target minio 9000
}

http://{$MINIO_CONSOLE_HOST} {
	redir https://{$MINIO_CONSOLE_HOST}{uri} permanent
}

https://{$MINIO_CONSOLE_HOST} {
	import dev_tls
	import proxy_target minio 9001
}
